# WooCommerce StoreOps environment example.
# Copy this file to .env and replace all placeholder secrets before running the system.

APP_HOST=127.0.0.1
APP_PORT=8088
ENVIRONMENT=production
SECRET_KEY=change-this-secret
LOG_LEVEL=INFO
LOG_FILE=app/logs/storeops.log
DATE_DISPLAY_MODE=jalali
TIMEZONE=Asia/Tehran

# Docker Compose database URL: use the PostgreSQL service name `postgres` when the Core Server runs inside Docker Compose.
DATABASE_URL=postgresql+psycopg://storeops:storeops_password@postgres:5432/storeops

# Local server database URL: use localhost/127.0.0.1 when running FastAPI or Alembic directly on your host machine.
# DATABASE_URL=postgresql+psycopg://storeops:storeops_password@127.0.0.1:5432/storeops

# Docker Compose Redis URLs: use the Redis service name `redis` inside Docker Compose.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Local Redis examples for host-machine development.
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

WORDPRESS_CONNECTOR_URL=https://example.com/wp-json/storeops/v1
WORDPRESS_API_KEY=change-this-wordpress-api-key
WORDPRESS_HMAC_SECRET=change-this-hmac-secret
REJECT_INSECURE_HTTP=true

INVENTORY_LOW_STOCK_THRESHOLD=2
INVENTORY_OLD_OOS_DAYS=30
INVENTORY_FULL_SCAN_CRON=0 3 * * *
INVENTORY_FAST_SCAN_INTERVAL_SECONDS=60

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WAREHOUSE_CHAT_ID=

STOREOPS_ADMIN_USERNAME=admin
STOREOPS_ADMIN_EMAIL=admin@example.com
STOREOPS_ADMIN_PASSWORD=change-this-admin-password

POSTGRES_DB=storeops
POSTGRES_USER=storeops
POSTGRES_PASSWORD=storeops_password
